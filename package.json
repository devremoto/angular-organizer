{
  "name": "angular-organizer",
  "author": {
    "name": "Adilson de Almeida Pedro",
    "email": "adilson@almeidapedro.com.br",
    "url": "https://adilson.almeidapedro.com.br",
    "github": "https://github.com/devremoto",
    "twitter": "https://twitter.com/devremoto",
    "linkedin": "https://www.linkedin.com/in/adilsonpedro/"
  },
  "displayName": "Angular Organizer",
  "description": "Organize Angular files: imports + class member ordering (@Input, @Output, etc.)",
  "version": "0.0.28",
  "publisher": "AdilsondeAlmeidaPedro",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Formatters"
  ],
  "activationEvents": [
    "onLanguage:typescript",
    "onCommand:angularOrganizer.debug.selfcheck",
    "onCommand:angularOrganizer.organizeAll",
    "onCommand:angularOrganizer.organizeAllWithProximity",
    "onCommand:angularOrganizer.sortImports",
    "onCommand:angularOrganizer.reorder.allMembers",
    "onCommand:angularOrganizer.reorder.constants",
    "onCommand:angularOrganizer.reorder.privateFields",
    "onCommand:angularOrganizer.reorder.protectedFields",
    "onCommand:angularOrganizer.reorder.inputs",
    "onCommand:angularOrganizer.reorder.inputSetters",
    "onCommand:angularOrganizer.reorder.outputs",
    "onCommand:angularOrganizer.reorder.viewQueries",
    "onCommand:angularOrganizer.reorder.accessors",
    "onCommand:angularOrganizer.reorder.ctor",
    "onCommand:angularOrganizer.reorder.publicMethods",
    "onCommand:angularOrganizer.reorder.protectedMethods",
    "onCommand:angularOrganizer.reorder.privateMethods",
    "onCommand:angularOrganizer.removeCommentsExceptRegions",
    "onCommand:angularOrganizer.removeRegions",
    "onCommand:angularOrganizer.convertToControlFlow",
    "onCommand:angularOrganizer.convertStructuralDirectiveAtCursor",
    "onCommand:angularOrganizer.hasStructuralDirectiveAtCursor"
  ],
  "extensionKind": [
    "workspace"
  ],
  "main": "./out/extension-optimized.js",
  "contributes": {
    "commands": [
      {
        "command": "angularOrganizer.debug.selfcheck",
        "title": "Angular Organizer: Self Check"
      },
      {
        "command": "angularOrganizer.organizeAll",
        "title": "Organize All"
      },
      {
        "command": "angularOrganizer.organizeAllWithProximity",
        "title": "Organize All (with Method Proximity)"
      },
      {
        "command": "angularOrganizer.sortImports",
        "title": "Sort Imports"
      },
      {
        "command": "angularOrganizer.reorder.allMembers",
        "title": "Reorder All Members"
      },
      {
        "command": "angularOrganizer.reorder.constants",
        "title": "Reorder Constants"
      },
      {
        "command": "angularOrganizer.reorder.privateFields",
        "title": "Reorder Private Fields"
      },
      {
        "command": "angularOrganizer.reorder.protectedFields",
        "title": "Reorder Protected Fields"
      },
      {
        "command": "angularOrganizer.reorder.inputs",
        "title": "Reorder @Inputs (properties)"
      },
      {
        "command": "angularOrganizer.reorder.inputSetters",
        "title": "Reorder @Input Setters"
      },
      {
        "command": "angularOrganizer.reorder.outputs",
        "title": "Reorder @Outputs"
      },
      {
        "command": "angularOrganizer.reorder.viewQueries",
        "title": "Reorder View Queries (@ViewChild)"
      },
      {
        "command": "angularOrganizer.reorder.accessors",
        "title": "Reorder Accessors (non-@Input)"
      },
      {
        "command": "angularOrganizer.reorder.ctor",
        "title": "Reorder Constructor"
      },
      {
        "command": "angularOrganizer.reorder.publicMethods",
        "title": "Reorder Public Methods"
      },
      {
        "command": "angularOrganizer.reorder.protectedMethods",
        "title": "Reorder Protected Methods"
      },
      {
        "command": "angularOrganizer.reorder.privateMethods",
        "title": "Reorder Private Methods"
      },
      {
        "command": "angularOrganizer.removeCommentsExceptRegions",
        "title": "Angular Organizer: Remove Comments"
      },
      {
        "command": "angularOrganizer.removeRegions",
        "title": "Angular Organizer: Remove Regions"
      },
      {
        "command": "angularOrganizer.convertToControlFlow",
        "title": "Convert All *ngIf, *ngFor, *ngSwitch to @if, @for, @switch"
      },
      {
        "command": "angularOrganizer.convertStructuralDirectiveAtCursor",
        "title": "Convert Current *ngIf, *ngFor, *ngSwitch to @if, @for, @switch (Cursor)"
      },
      {
        "command": "angularOrganizer.hasStructuralDirectiveAtCursor",
        "title": "Check for Structural Directive at Cursor"
      },
      {
        "command": "angularOrganizer.toggleRegions",
        "title": "Toggle regions"
      },
      {
        "command": "angularOrganizer.organizeAllWithCleanup",
        "title": "Organize All (remove comments)"
      },
      {
        "command": "angularOrganizer.convertToStructuralDirectives",
        "title": "Convert @if, @for, @switch to *ngIf, *ngFor, *ngSwitch"
      }
    ],
    "submenus": [
      {
        "id": "angularOrganizer.menu",
        "label": "Angular Organizer"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "submenu": "angularOrganizer.menu",
          "when": "editorLangId == typescript || editorLangId == html",
          "group": "1_modification@10"
        }
      ],
      "explorer/context": [
        {
          "submenu": "angularOrganizer.menu",
          "when": "resourceExtname == .ts || resourceExtname == .html",
          "group": "7_modification@10"
        }
      ],
      "angularOrganizer.menu": [
        {
          "command": "angularOrganizer.organizeAll",
          "group": "0_main@10",
          "when": "editorLangId == typescript || resourceExtname == .ts"
        },
        {
          "command": "angularOrganizer.organizeAllWithCleanup",
          "group": "0_main@11",
          "when": "editorLangId == typescript || resourceExtname == .ts"
        },
        {
          "command": "angularOrganizer.organizeAllWithProximity",
          "group": "0_main@12",
          "when": "editorLangId == typescript || resourceExtname == .ts"
        },
        {
          "command": "angularOrganizer.sortImports",
          "group": "0_main@13",
          "when": "editorLangId == typescript || resourceExtname == .ts"
        },
        {
          "command": "angularOrganizer.toggleRegions",
          "group": "0_main@14",
          "when": "editorLangId == typescript || resourceExtname == .ts"
        },
        {
          "command": "angularOrganizer.convertToControlFlow",
          "group": "1_refactor@09",
          "when": "editorLangId == html || resourceExtname == .html || angularOrganizer.hasTemplateUrl"
        },
        {
          "command": "angularOrganizer.convertToStructuralDirectives",
          "group": "1_refactor@10",
          "when": "editorLangId == html || resourceExtname == .html || angularOrganizer.hasTemplateUrl"
        },
        {
          "command": "angularOrganizer.convertStructuralDirectiveAtCursor",
          "group": "1_refactor@11",
          "when": "editorLangId == html || resourceExtname == .html || angularOrganizer.hasTemplateUrl"
        }
      ],
      "commandPalette": [
        {
          "command": "angularOrganizer.removeCommentsExceptRegions"
        },
        {
          "command": "angularOrganizer.removeRegions"
        },
        {
          "command": "angularOrganizer.convertToControlFlow",
          "title": "Convert *ngIf, *ngFor, *ngSwitch to @if, @for, @switch",
          "group": "0_main@40"
        },
        {
          "command": "angularOrganizer.convertStructuralDirectiveAtCursor",
          "when": "editorLangId == html || editorLangId == typescript"
        }
      ]
    },
    "keybindings": [
      {
        "command": "angularOrganizer.convertStructuralDirectiveAtCursor",
        "key": "ctrl+shift+2",
        "mac": "cmd+shift+2",
        "when": "editorTextFocus && (editorLangId == html || editorLangId == typescript)"
      }
    ],
    "configuration": {
      "title": "Angular Organizer",
      "properties": {
        "angularOrganizer.emitRegions": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, surround each member group with //#region ... //#endregion .... Turn off to omit regions."
        },
        "angularOrganizer.formatAfterOrganize": {
          "type": "boolean",
          "default": true,
          "description": "After running an Angular Organizer command, also run the editor's Format Document."
        },
        "angularOrganizer.cleanupCommentsOnOrganize": {
          "type": "boolean",
          "default": false,
          "description": "If true, remove all comments (except //#region and //#endregion lines) after running an Angular Organizer command."
        },
        "angularOrganizer.removeBlankLinesBeforeOrganize": {
          "type": "boolean",
          "default": true,
          "description": "Before organizing, remove empty lines that are outside strings/template literals."
        },
        "angularOrganizer.optimizeMethodProximity": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, methods are organized based on usage proximity - methods that call each other are placed closer together."
        },
        "angularOrganizer.removeUnusedImports": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, automatically remove unused imports during organization."
        },
        "angularOrganizer.removeUnusedVariables": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, automatically remove unused private variables and methods during organization."
        },
        "angularOrganizer.ensureBlankLineAfterImports": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, ensure there is a blank line after the import statements."
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/devremoto/angular-organizer"
  },
  "bugs": {
    "url": "https://github.com/devremoto/angular-organizer/issues"
  },
  "icon": "assets/angular.ico",
  "keywords": [
    "angular",
    "organize",
    "formatter",
    "imports",
    "typescript"
  ],
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -w -p .",
    "build": "npm run build:dev",
    "build:dev": "tsc -p . && npm run build:organize",
    "build:prod": "npm run build:optimized && npm run build:organize",
    "build:optimized": "esbuild src/extension-optimized.ts src/template-converter.ts src/text-utils.ts --bundle --platform=node --format=cjs --outdir=out --sourcemap --external:vscode --external:./organize.js",
    "build:organize": "esbuild src/organize.ts --bundle --platform=node --format=cjs --outfile=out/organize.js --sourcemap --external:vscode",
    "package": "vsce package",
    "publish": "vsce publish",
    "cleanup-vsix": "node scripts/cleanup-vsix.js",
    "test": "npm run test:optimized && npm run test:proximity && npm run test:ng-destroy && npm run test:comments && npm run test:hooks && npm run test:control-flow && npm run test:context-menu && npm run test:element-wrapping && npm run test:regions",
    "test:optimized": "node tests/test-optimized-bundle.mjs",
    "test:proximity": "node tests/test-proximity.mjs",
    "test:ng-destroy": "node tests/test-ng-destroy.mjs",
    "test:comments": "node tests/test-comment-removal.mjs",
    "test:hooks": "node tests/test-post-commit.mjs",
    "test:control-flow": "node tests/test-control-flow-conversion.mjs",
    "test:context-menu": "node tests/test-context-menu.mjs",
    "test:element-wrapping": "node tests/test-element-wrapping.mjs",
    "test:regions": "node tests/test-remove-regions.mjs"
  },
  "dependencies": {
    "ts-morph": "^22.0.0",
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "@types/node": "^24.6.2",
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.25.10",
    "ts-morph": "^22.0.0",
    "typescript": "^5.4.0",
    "vsce": "^2.15.0"
  }
}